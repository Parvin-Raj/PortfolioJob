# Contact form — choose one delivery method (or use FormSubmit fallback automatically)

CONTACT_TO_EMAIL=parvinraj0607@gmail.com

# Option A: Gmail SMTP (recommended once App Password is valid)
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password into SMTP_PASS (spaces are OK — stripped automatically)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=parvinraj0607@gmail.com
SMTP_PASS=your_gmail_app_password_here
